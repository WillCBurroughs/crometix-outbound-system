generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id            String   @id @default(uuid())

  apolloId      String?  @unique

  firstName     String?
  lastName      String?
  email         String?

  companyName   String?

  websiteUrl    String?

  city          String?
  state         String?

  linkedinUrl   String?

  websiteScore  Int?
  performance   Int?
  seo           Int?
  accessibility Int?
  bestPractices Int?

  status        String   @default("NEW")

  errorMessage  String?

  reportUrl     String?

  instantlyId   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}